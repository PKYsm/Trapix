<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trapix_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/trapix_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_shield" app:tint="@color/trapix_accent"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRAPIX" android:textColor="@color/trapix_text_primary" android:textSize="18sp" android:textStyle="bold" android:letterSpacing="0.2" android:layout_marginStart="10dp"/>
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Stats bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Intruder Captures"
                android:textColor="@color/trapix_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvCaptureCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 captures"
                android:textColor="@color/trapix_accent"
                android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </LinearLayout>

        <!-- Search bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/trapix_card"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="16sp"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Search by date, attempt, camera..."
                    android:textColor="@color/trapix_text_primary"
                    android:textColorHint="@color/trapix_text_secondary"
                    android:textSize="14sp"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:singleLine="true"/>

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_close"
                    android:visibility="gone"
                    android:padding="2dp"
                    app:tint="@color/trapix_text_secondary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Camera filter chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCamAll"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textColor="@color/trapix_text_primary"
                app:chipBackgroundColor="@color/trapix_card"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCamFront"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Front"
                android:textColor="@color/trapix_text_primary"
                app:chipBackgroundColor="@color/trapix_card"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCamRear"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📸 Rear"
                android:textColor="@color/trapix_text_primary"
                app:chipBackgroundColor="@color/trapix_card"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- Date filter chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDateAll"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Time"
                android:textColor="@color/trapix_text_primary"
                app:chipBackgroundColor="@color/trapix_card"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDateToday"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="@color/trapix_text_primary"
                app:chipBackgroundColor="@color/trapix_card"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDateWeek"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Week"
                android:textColor="@color/trapix_text_primary"
                app:chipBackgroundColor="@color/trapix_card"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDateMonth"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Month"
                android:textColor="@color/trapix_text_primary"
                app:chipBackgroundColor="@color/trapix_card"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- Permission status chips (shown inline, compact) -->
        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPermCamera"
                style="@style/Widget.Material3.Chip.Suggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Camera"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/trapix_card"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPermLocation"
                style="@style/Widget.Material3.Chip.Suggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Location"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/trapix_card"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- Empty state -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_captures_yet"
            android:textColor="@color/trapix_text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingTop="60dp"
            android:lineSpacingExtra="6dp"
            android:visibility="gone"/>

        <!-- Gallery -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvIntruders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_settings"
        app:backgroundTint="@color/trapix_accent"
        app:tint="@color/trapix_bg"
        app:layout_anchor="@id/rvIntruders"
        app:layout_anchorGravity="bottom|end"
        android:layout_margin="16dp"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
